{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Search",
  "version": "0.1.0",
  "identifier": "com.audiosearch.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix \"$(git rev-parse --show-toplevel)/frontend\" run dev",
    "beforeBuildCommand": "npm --prefix \"$(git rev-parse --show-toplevel)/frontend\" run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/pyenv": "resources/pyenv",
      "resources/bin": "resources/bin",
      "resources/backend": "resources/backend"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
