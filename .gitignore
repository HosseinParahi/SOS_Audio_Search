# macOS
.DS_Store

# Python / uv
backend/.venv/
__pycache__/
*.pyc

# App data: index DB, model output, transcode/peak caches (regenerated)
backend/data/

# Node / Vite
frontend/node_modules/
frontend/dist/

# Logs
*.log

# Tauri (Rust build output + generated)
src-tauri/target/
src-tauri/gen/

# Bundled resources are generated by scripts/build-pyenv.sh + bundle-ffmpeg.sh (the embedded
# Python env, ffmpeg, and backend source — gigabytes). Ignore the heavy contents but keep the
# directory placeholders so a fresh checkout still compiles (the Tauri build script validates
# that these resource paths exist, even for `tauri dev`).
src-tauri/resources/**
!src-tauri/resources/
!src-tauri/resources/pyenv/
!src-tauri/resources/bin/
!src-tauri/resources/backend/
!src-tauri/resources/**/.gitkeep
